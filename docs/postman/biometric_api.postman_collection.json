    {
      "name": "Maintenance",
      "description": "Historial de mantenimientos preventivos, correctivos y reparaciones (fase 04). Soporta carga opcional de PDF en `pdf_file` (multipart). Tipos válidos: `PREVENTIVE`, `CORRECTIVE`, `REPAIR`.",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/maintenance/records/?ordering=-date",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "maintenance", "records", ""],
              "query": [
                { "key": "ordering",     "value": "-date" },
                { "key": "equipment",    "value": "{{equipment_id}}", "disabled": true },
                { "key": "branch",       "value": "{{branch_id}}",    "disabled": true },
                { "key": "kind",         "value": "PREVENTIVE",       "disabled": true },
                { "key": "date_after",   "value": "2026-01-01",       "disabled": true },
                { "key": "date_before",  "value": "2026-12-31",       "disabled": true },
                { "key": "search",       "value": "calibracion",      "disabled": true }
              ]
            },
            "description": "Filtros: `equipment`, `branch` (vía `equipment__branch_id`), `kind`, `date_after`, `date_before`. Search: `description`, `technician`, `equipment__asset_tag`. Ordering: `date`, `created_at`, `cost` (default `-date`)."
          }
        },
        {
          "name": "Create (JSON, sin PDF)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"equipment\": {{equipment_id}},\n  \"kind\": \"PREVENTIVE\",\n  \"date\": \"2026-04-15\",\n  \"description\": \"Limpieza general y calibración trimestral.\",\n  \"technician\": \"Juan Perez\",\n  \"cost\": \"150000.00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/maintenance/records/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "maintenance", "records", ""]
            },
            "description": "Crea un registro histórico sin PDF. La fecha no puede ser futura. La descripción no puede estar vacía. `cost` es opcional, debe ser >= 0."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('maintenance_record_id', body.id);",
                  "  if (pm.environment && pm.environment.name) pm.environment.set('maintenance_record_id', body.id);",
                  "}",
                  "pm.test('pdf_file_url null cuando no se sube PDF', () => pm.expect(body.pdf_file_url).to.be.null);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create (multipart, con PDF)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "equipment",   "value": "{{equipment_id}}",                  "type": "text" },
                { "key": "kind",        "value": "CORRECTIVE",                         "type": "text" },
                { "key": "date",        "value": "2026-04-20",                         "type": "text" },
                { "key": "description", "value": "Cambio de batería y sensor SpO2",   "type": "text" },
                { "key": "technician",  "value": "Maria Lopez",                        "type": "text" },
                { "key": "cost",        "value": "420000.00",                          "type": "text" },
                { "key": "pdf_file",    "type": "file", "src": [], "description": "Selecciona un archivo .pdf local (max 10 MB)." }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/maintenance/records/",
              "host": ["{{base_url}}"],
