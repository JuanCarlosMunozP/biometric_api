            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor de signos vitales\",\n  \"asset_tag\": \"{{asset_tag_sample}}\",\n  \"brand\": \"Philips\",\n  \"model\": \"MX450\",\n  \"branch\": {{branch_id}},\n  \"location\": \"UCI - cama 3\",\n  \"purchase_date\": \"2024-08-15\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/equipment/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "equipment", ""]
            },
            "description": "Genera el QR automáticamente. La response trae `qr_code_url` apuntando al PNG."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('equipment_id', body.id);",
                  "  if (pm.environment && pm.environment.name) pm.environment.set('equipment_id', body.id);",
                  "}",
                  "pm.test('qr_code_url presente', () => pm.expect(body.qr_code_url).to.be.a('string').and.not.empty);"
                ]
              }
            }
